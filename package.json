{
  "name": "statuspage-customisations",
  "version": "1.0.0",
  "description": "Custom code for uses of statuspage.io on projects owned by the Government Digital Service.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alphagov/statuspage-customisations.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alphagov/statuspage-customisations/issues"
  },
  "homepage": "https://github.com/alphagov/statuspage-customisations#readme",
  "scripts": {
    "lint": "npm run lint:mjs && npm run lint:scss",
    "lint:mjs": "standard src/**/*.mjs",
    "lint:scss": "stylelint src/**/*.scss",
    "test": "npm run lint && concurrently \"npm run test:only\" \"npm run dev\" --kill-others",
    "test:only": "wdio run ./tests/$TEAM/config.mjs",
    "dev": "nodemon ./server/serve.mjs",
    "refresh": "node -e 'import(\"./server/helpers/generateTemplatesFromRemote.mjs\").then( module => module.generateAllTemplatesFromRemote())'",
    "build": "npm run build:css && npm run build:js && npm run build:html",
    "build:css": "sass --no-source-map src/$TEAM/custom.scss dist/$TEAM/custom.css",
    "build:js": "rollup src/$TEAM/custom-footer.mjs --file dist/$TEAM/custom-footer.js --format iife",
    "build:html": "cp src/$TEAM/custom-footer.html dist/$TEAM/custom-footer.html"
  },
  "devDependencies": {
    "@wdio/cli": "9.20.0",
    "@wdio/jasmine-framework": "9.20.0",
    "@wdio/local-runner": "9.20.0",
    "@wdio/spec-reporter": "9.20.0",
    "cheerio": "1.1.2",
    "concurrently": "10.0.3",
    "nodemon": "3.1.10",
    "nunjucks": "3.2.4",
    "rollup": "4.61.1",
    "sass": "1.93.2",
    "standard": "17.1.2",
    "stylelint": "16.25.0",
    "stylelint-config-gds": "2.0.0"
  },
  "standard": {
    "globals": [
      "$"
    ]
  },
  "stylelint": {
    "extends": "stylelint-config-gds/scss",
    "overrides": [
      {
        "files": "**/*.scss",
        "rules": {
          "declaration-no-important": null,
          "selector-no-qualifying-type": null,
          "scss/comment-no-loud": null
        }
      }
    ]
  },
  "nodemonConfig": {
    "ignore": [
      "*.spec.js",
      "**/server/**/*.mjs",
      "src/**/*.scss",
      "src/**/*.mjs"
    ],
    "ext": "js,html,css"
  }
}
